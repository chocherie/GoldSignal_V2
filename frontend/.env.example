# Dev proxy: Vite forwards /api and /health → http://127.0.0.1:${VITE_API_PORT}
# MUST match `uvicorn ... --port N` (default is 8000). If the UI says Offline / Failed to fetch,
# start the API from the repo: ./scripts/start_api.sh — then open http://127.0.0.1:8000/health in the browser.
# If you use another port, copy this to .env.local, set VITE_API_PORT, restart `npm run dev`.

VITE_API_PORT=8000

# Production / hosted UI: absolute API origin (no trailing slash). Empty = same-origin / dev proxy.
# Example: VITE_API_BASE=https://gold-api.fly.dev
# VITE_API_BASE=
