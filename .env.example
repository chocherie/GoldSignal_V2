# Backend market-data source (Supabase Postgres / PostgREST)
SUPABASE_URL=https://<your-project>.supabase.co
SUPABASE_SERVICE_KEY=<service-role-key>
GOLD_SUPABASE_TABLE=daily_prices
GOLD_SUPABASE_START=1990-01-01

# Optional: cached panel TTL (seconds) before reloading from Supabase
GOLD_CACHE_TTL_SECONDS=300
